# =====================================================================
# .env.example — copy to .env for local overrides.
# .env is git-ignored. NEVER commit real credentials.
# =====================================================================

# Active Spring profile: local | dev | stg | prod
SPRING_PROFILES_ACTIVE=local

# Database (required for dev/stg/prod profiles; ignored by local/H2)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=boilerplate
DB_USERNAME=root
DB_PASSWORD=1234
